            },
            "description": "Update an existing category (Admin authentication required)"
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/categories/6",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "categories", "6"]
            },
            "description": "Delete a category (Admin authentication required, must have no products)"
          }
        }
      ]
    },

  "item": [
    {
      "name": "PUBLIC - Products",
      "item": [
        {
          "name": "List All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "products"]
            },
            "description": "Get paginated list of all products (public access)"
          }
        },
        {
          "name": "Get Product Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/products/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "products", "1"]
            },
            "description": "Get details of a specific product (public access)"
          }
        }
      ]
    },
    {
      "name": "PUBLIC - Categories",
